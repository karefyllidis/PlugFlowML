{
    "_comment": "Minimal sampling for SLURM/local smoke tests. Submit with HYDRAI_ML_CONFIG pointing here (see scripts/cluster/run_training_smoke_gpu_partition.sh).",

    "reactants": ["ethane"],
    "max_combinations_per_reactant": 2,
    "output_dir": "data/training",
    "save_interval": 1,
    "sampling_method": "latin",
    "lhs_seed": 42,
    "n_jobs": 1,
    "save_complete_csv": false,

    "parameter_ranges": {
        "temperature_K": [800, 900, 3],
        "pressure_bar": [1.5, 2.5, 3],
        "length_m": [3.0, 6.0, 3],
        "diameter_mm": [20.0, 35.0, 3],
        "mass_flow_rate_kgps": [0.05, 0.09, 3],
        "heat_flux_Wm2": [100000, 180000, 3]
    }
}
